PBR
{
$basetexture			"dj\backstage\backpanels_64_yellow_basecolor"
$basetexturetransform	"center 0 0 scale 1 1 rotate 0 translate 0 0"
$bumpmap				"dj\backstage\backpanels_64_normal"
$bumptransform			"center 0 0 scale 1 1 rotate 0 translate 0 0"
$mraotexture			"dj\backstage\backpanels_64_mrao"
$mraoscale              "[1.0 1.0 1.0]"

//$parallax               1
//$parallaxcenter			0.5
//$parallaxdepth			0.01
//$parallaxdither         1
//$parallaxscale          256

$envmaplightscale		1
$envmaptint 			0.5

$reflectivity			"[ 0.6 0.6 0.6 ]" 
$surfaceprop			metal
"%noportal"				1
}
