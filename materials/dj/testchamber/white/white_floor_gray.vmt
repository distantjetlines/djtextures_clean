PBR
{
$basetexture			"dj\testchamber\white\white_floor_gray_basecolor"
$basetexturetransform	"center 0 0 scale 1 1 rotate 0 translate 0 0"
$bumpmap				"dj\testchamber\white\white_floor_normal"
$bumptransform			"center 0 0 scale 1 1 rotate 0 translate 0 0"
$mraotexture			"dj\testchamber\white\white_floor_mrao"
$mraoscale              "[1.0 0.8 1.0]"

$detail					"dj\detail\white_detail_ambientocclusion"
$detailblendfactor		0.3
$detailblendmode		8
$detailtransform        "center 0 0 scale 160 160 rotate 0 translate 0 0"
$detailmask				"dj\testchamber\white\white_floor_detail_mask"

//$parallax               1
//$parallaxcenter			0.5
//$parallaxdepth			0.01
//$parallaxdither         1
//$parallaxscale          256

$envmaplightscale		1
$envmaptint 			0.5

$reflectivity			"[ 0.8 0.8 0.8 ]" 
$surfaceprop			concrete
}
